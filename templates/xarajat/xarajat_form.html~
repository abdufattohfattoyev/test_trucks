<!-- templates/xarajat/xarajat_form.html -->

<div class="xarajat-form-wrapper">
    <form method="post"
          enctype="multipart/form-data"
          action="{% if action == 'add' %}{% url 'xarajat_add' %}{% else %}{% url 'xarajat_edit' xarajat_id %}{% endif %}"
          class="ajax-form expense-form">
        {% csrf_token %}

        <!-- Truck Field -->
        <div class="form-group">
            <label for="id_truck" class="form-label">
                <i class="bi bi-truck"></i>
                <span>Truck</span>
                <span class="required">*</span>
            </label>
            {{ form.truck }}
            <div id="id_truck_error" class="invalid-feedback"></div>
        </div>

        <!-- Expense Type Field -->
        <div class="form-group">
            <label for="id_expense_type" class="form-label">
                <i class="bi bi-tag"></i>
                <span>Expense Type</span>
                <span class="required">*</span>
            </label>
            {{ form.expense_type }}
            <div id="id_expense_type_error" class="invalid-feedback"></div>
        </div>

        <!-- Amount Field -->
        <div class="form-group">
            <label for="id_amount" class="form-label">
                <i class="bi bi-currency-dollar"></i>
                <span>Amount</span>
                <span class="required">*</span>
            </label>
            <div class="amount-input-wrapper">
                <span class="amount-prefix">$</span>
                {{ form.amount }}
            </div>
            <div id="id_amount_error" class="invalid-feedback"></div>
        </div>

        <!-- Date Field -->
        <div class="form-group">
            <label for="id_date" class="form-label">
                <i class="bi bi-calendar3"></i>
                <span>Date</span>
                <span class="required">*</span>
            </label>
            {{ form.date }}
            <div id="id_date_error" class="invalid-feedback"></div>
        </div>

        <!-- Description Field -->
        <div class="form-group">
            <label for="id_description" class="form-label">
                <i class="bi bi-card-text"></i>
                <span>Description</span>
            </label>
            {{ form.description }}
            <div id="id_description_error" class="invalid-feedback"></div>
            <small class="form-hint">Optional: Add additional details about this expense</small>
        </div>

        <!-- Document Field - IMPROVED VERSION -->
        <div class="form-group">
            <label class="form-label">
                <i class="bi bi-file-earmark-pdf"></i>
                <span>Document</span>
            </label>
            <div class="file-input-wrapper">
                <!-- File input -->
                <input type="file"
                       name="document"
                       id="id_document"
                       class="file-input-hidden"
                       accept=".jpg,.jpeg,.png,.pdf,.doc,.docx">

                <!-- Upload Area -->
                <label for="id_document" class="file-input-label" id="fileUploadLabel">
                    <i class="bi bi-cloud-upload"></i>
                    <span class="file-label-text">Choose file or drag here</span>
                </label>

                <!-- Selected File Display - ENHANCED -->
                <div class="selected-file-display" id="selectedFileDisplay" style="display: none;">
                    <div class="file-icon-success">
                        <i class="bi bi-file-earmark-check-fill"></i>
                    </div>
                    <div class="file-info-wrapper">
                        <span class="selected-file-name" id="selectedFileName">filename.pdf</span>
                        <span class="selected-file-size" id="selectedFileSize">0 KB</span>
                        <span class="file-status-badge">
                            <i class="bi bi-check-circle-fill"></i>
                            Ready to upload
                        </span>
                    </div>
                    <button type="button" class="remove-file-btn" id="removeFileBtn">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
            <div id="id_document_error" class="invalid-feedback"></div>

            {% if action == 'edit' and form.instance.document %}
            <div class="current-document">
                <a href="{{ form.instance.document.url }}" target="_blank" class="current-doc-link">
                    <i class="bi bi-file-earmark-check"></i>
                    <span>Current: {{ form.instance.original_file_name|default:"Document" }}</span>
                </a>
            </div>
            {% endif %}

            <small class="form-hint">Supported: JPG, PNG, PDF, DOC, DOCX (Max 50MB)</small>
        </div>

        <!-- Form Actions -->
        <div class="form-actions">
            <button type="button"
                    onclick="window.closeFormSidebar ? window.closeFormSidebar() : history.back()"
                    class="btn-cancel">
                <i class="bi bi-x-lg"></i>
                <span>Cancel</span>
            </button>
            <button type="submit" class="btn-submit">
                <i class="bi {% if action == 'add' %}bi-plus-lg{% else %}bi-check-lg{% endif %}"></i>
                <span>{% if action == 'add' %}Add Expense{% else %}Save Changes{% endif %}</span>
            </button>
        </div>
    </form>
</div>

<style>
:root {
    --form-primary: #2563eb;
    --form-accent: #7c3aed;
    --form-success: #10b981;
    --form-danger: #ef4444;
    --form-gray-50: #f8fafc;
    --form-gray-100: #f1f5f9;
    --form-gray-200: #e2e8f0;
    --form-gray-600: #475569;
    --form-gray-700: #334155;
    --form-gray-800: #1e293b;
    --form-radius: 8px;
    --form-transition: all 0.3s ease;
}

.xarajat-form-wrapper {
    padding: 0;
}

.expense-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.form-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--form-gray-800);
    margin: 0;
}

.form-label i {
    font-size: 1.125rem;
    color: var(--form-primary);
}

.required {
    color: var(--form-danger);
    font-weight: 700;
}

.expense-form input[type="text"],
.expense-form input[type="number"],
.expense-form input[type="date"],
.expense-form select,
.expense-form textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--form-gray-200);
    border-radius: var(--form-radius);
    font-size: 0.9375rem;
    color: var(--form-gray-800);
    background: white;
    transition: var(--form-transition);
}

.expense-form input:focus,
.expense-form select:focus,
.expense-form textarea:focus {
    outline: none;
    border-color: var(--form-primary);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

.expense-form textarea {
    min-height: 100px;
    resize: vertical;
    font-family: inherit;
}

.amount-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.amount-prefix {
    position: absolute;
    left: 1rem;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--form-gray-700);
    pointer-events: none;
    z-index: 1;
}

.amount-input-wrapper input {
    padding-left: 2.5rem !important;
}

/* ========== FILE UPLOAD ENHANCED STYLES ========== */
.file-input-wrapper {
    position: relative;
}

.file-input-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
}

.file-input-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 2rem 1rem;
    border: 2px dashed var(--form-gray-200);
    border-radius: var(--form-radius);
    background: var(--form-gray-50);
    cursor: pointer;
    transition: var(--form-transition);
}

.file-input-label:hover {
    border-color: var(--form-primary);
    background: rgba(37, 99, 235, 0.02);
    transform: translateY(-2px);
}

.file-input-label i {
    font-size: 2.5rem;
    color: var(--form-primary);
}

.file-label-text {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--form-gray-700);
}

/* Enhanced selected file display */
.selected-file-display {
    display: none;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.08) 0%, rgba(5, 150, 105, 0.08) 100%);
    border: 2px solid rgba(16, 185, 129, 0.3);
    border-radius: var(--form-radius);
    animation: slideIn 0.3s ease;
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.1);
}

.selected-file-display.active {
    display: flex !important;
}

@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.file-icon-success {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    background: linear-gradient(135deg, var(--form-success) 0%, #059669 100%);
    border-radius: 10px;
    flex-shrink: 0;
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
}

.file-icon-success i {
    font-size: 1.875rem;
    color: white;
}

.file-info-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
    min-width: 0;
}

.selected-file-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--form-gray-800);
    word-break: break-all;
    line-height: 1.3;
}

.selected-file-size {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--form-gray-600);
}

.file-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.625rem;
    background: rgba(16, 185, 129, 0.15);
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--form-success);
    width: fit-content;
    margin-top: 0.125rem;
}

.file-status-badge i {
    font-size: 0.875rem;
}

.remove-file-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(239, 68, 68, 0.1);
    border: 2px solid rgba(239, 68, 68, 0.2);
    border-radius: 8px;
    color: var(--form-danger);
    cursor: pointer;
    transition: var(--form-transition);
    flex-shrink: 0;
}

.remove-file-btn:hover {
    background: var(--form-danger);
    border-color: var(--form-danger);
    color: white;
    transform: scale(1.1) rotate(5deg);
}

.remove-file-btn:active {
    transform: scale(0.95) rotate(0deg);
}

.remove-file-btn i {
    font-size: 1rem;
}

.current-document {
    margin-top: 0.75rem;
}

.current-doc-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: var(--form-radius);
    color: var(--form-success);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
    transition: var(--form-transition);
}

.current-doc-link:hover {
    background: rgba(16, 185, 129, 0.15);
}

.form-hint {
    font-size: 0.8125rem;
    color: var(--form-gray-600);
}

.is-invalid {
    border-color: var(--form-danger) !important;
}

.invalid-feedback {
    display: none;
    font-size: 0.8125rem;
    color: var(--form-danger);
    font-weight: 500;
}

.invalid-feedback:not(.d-none) {
    display: block;
}

.form-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--form-gray-200);
}

.btn-cancel,
.btn-submit {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    border: none;
    border-radius: var(--form-radius);
    font-size: 0.9375rem;
    font-weight: 600;
    cursor: pointer;
    transition: var(--form-transition);
}

.btn-cancel {
    background: var(--form-gray-100);
    color: var(--form-gray-700);
}

.btn-cancel:hover {
    background: var(--form-gray-200);
}

.btn-submit {
    background: linear-gradient(135deg, var(--form-primary) 0%, var(--form-accent) 100%);
    color: white;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
}

.btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.4);
}

@media (max-width: 768px) {
    .form-actions {
        flex-direction: column;
    }

    .file-icon-success {
        width: 48px;
        height: 48px;
    }

    .file-icon-success i {
        font-size: 1.625rem;
    }

    .selected-file-display {
        padding: 1rem;
    }
}
</style>

<script>
console.log('═══════════════════════════════════════');
console.log('🚀 FILE UPLOAD SYSTEM INITIALIZING');
console.log('═══════════════════════════════════════');

(function() {
    'use strict';

    // Format file size helper
    function formatFileSize(bytes) {
        if (bytes === 0) return '0 Bytes';
        const k = 1024;
        const sizes = ['Bytes', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
    }

    // Initialize file upload
    function initFileUpload() {
        console.log('📁 Initializing file upload components...');

        const fileInput = document.getElementById('id_document');
        const uploadLabel = document.getElementById('fileUploadLabel');
        const fileDisplay = document.getElementById('selectedFileDisplay');
        const fileName = document.getElementById('selectedFileName');
        const fileSize = document.getElementById('selectedFileSize');
        const removeBtn = document.getElementById('removeFileBtn');

        // Check elements
        console.log('🔍 Element verification:');
        console.log('  fileInput:', fileInput ? '✅' : '❌');
        console.log('  uploadLabel:', uploadLabel ? '✅' : '❌');
        console.log('  fileDisplay:', fileDisplay ? '✅' : '❌');
        console.log('  fileName:', fileName ? '✅' : '❌');
        console.log('  fileSize:', fileSize ? '✅' : '❌');
        console.log('  removeBtn:', removeBtn ? '✅' : '❌');

        if (!fileInput || !uploadLabel || !fileDisplay) {
            console.error('❌ CRITICAL: Required elements missing!');
            return;
        }

        // Handle file selection
        fileInput.addEventListener('change', function(e) {
            console.log('');
            console.log('═══════════════════════════════════════');
            console.log('📄 FILE SELECTED');
            console.log('═══════════════════════════════════════');

            if (!this.files || this.files.length === 0) {
                console.log('⚠️ No files selected');
                return;
            }

            const file = this.files[0];
            const fileSizeFormatted = formatFileSize(file.size);

            console.log('📌 File Details:');
            console.log('  Name:', file.name);
            console.log('  Size:', fileSizeFormatted);
            console.log('  Type:', file.type);
            console.log('═══════════════════════════════════════');

            // Hide upload label
            if (uploadLabel) {
                uploadLabel.style.display = 'none';
                console.log('✅ Upload label hidden');
            }

            // Show file display
            if (fileDisplay) {
                fileDisplay.style.display = 'flex';
                fileDisplay.classList.add('active');
                console.log('✅ File display shown');
            }

            // Update file name
            if (fileName) {
                fileName.textContent = file.name;
                console.log('✅ File name updated');
            }

            // Update file size
            if (fileSize) {
                fileSize.textContent = fileSizeFormatted;
                console.log('✅ File size updated');
            }

            console.log('');
            console.log('🎉 FILE SUCCESSFULLY DISPLAYED!');
            console.log('');
        });

        // Handle remove button
        if (removeBtn) {
            removeBtn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();

                console.log('');
                console.log('═══════════════════════════════════════');
                console.log('🗑️ REMOVING FILE');
                console.log('═══════════════════════════════════════');

                // Clear file input
                if (fileInput) {
                    fileInput.value = '';
                    console.log('✅ File input cleared');
                }

                // Show upload label
                if (uploadLabel) {
                    uploadLabel.style.display = 'flex';
                    console.log('✅ Upload label shown');
                }

                // Hide file display
                if (fileDisplay) {
                    fileDisplay.style.display = 'none';
                    fileDisplay.classList.remove('active');
                    console.log('✅ File display hidden');
                }

                console.log('═══════════════════════════════════════');
                console.log('✅ FILE REMOVED SUCCESSFULLY!');
                console.log('═══════════════════════════════════════');
                console.log('');
            });
        }

        // Drag and drop support
        if (uploadLabel) {
            uploadLabel.addEventListener('dragover', function(e) {
                e.preventDefault();
                e.stopPropagation();
                this.style.borderColor = 'var(--form-primary)';
                this.style.background = 'rgba(37, 99, 235, 0.05)';
            });

            uploadLabel.addEventListener('dragleave', function(e) {
                e.preventDefault();
                e.stopPropagation();
                this.style.borderColor = 'var(--form-gray-200)';
                this.style.background = 'var(--form-gray-50)';
            });

            uploadLabel.addEventListener('drop', function(e) {
                e.preventDefault();
                e.stopPropagation();
                this.style.borderColor = 'var(--form-gray-200)';
                this.style.background = 'var(--form-gray-50)';

                console.log('');
                console.log('📥 FILE DROPPED');

                const files = e.dataTransfer.files;
                if (files.length > 0) {
                    fileInput.files = files;
                    // Trigger change event
                    const event = new Event('change', { bubbles: true });
                    fileInput.dispatchEvent(event);
                }
            });
        }

        console.log('');
        console.log('═══════════════════════════════════════');
        console.log('✅ FILE UPLOAD SYSTEM READY!');
        console.log('═══════════════════════════════════════');
        console.log('');
    }

    // Initialize other form fields
    function initFormFields() {
        console.log('📝 Initializing other form fields...');

        // Amount input
        const amountInput = document.querySelector('input[name="amount"]');
        if (amountInput) {
            amountInput.setAttribute('type', 'text');
            amountInput.setAttribute('inputmode', 'decimal');
            amountInput.setAttribute('placeholder', '0.00');
            console.log('✅ Amount input configured');
        }

        // Date input
        const dateInput = document.querySelector('input[name="date"]');
        if (dateInput && !dateInput.value) {
            dateInput.value = new Date().toISOString().split('T')[0];
            console.log('✅ Date set to today');
        }

        console.log('✅ Form fields initialized');
    }

    // Initialize when DOM is ready
    function initialize() {
        console.log('🎬 Starting initialization...');
        initFileUpload();
        initFormFields();
        console.log('🎯 All systems initialized!');
    }

    // Run initialization
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
            console.log('✅ DOM Content Loaded');
            setTimeout(initialize, 50);
        });
    } else {
        console.log('✅ DOM Already Ready');
        setTimeout(initialize, 50);
    }

})();
</script>
{% extends 'base.html' %}
{% load static %}

{% block title %}{{ truck.po_id }}: {{ truck.make }} {{ truck.model }}{% endblock %}

{% block extra_css %}
<style>
    .detail-page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .detail-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--gray-800);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .detail-page-title .po-tag {
        font-size: 0.875rem;
        background: rgba(37,99,235,0.1);
        color: var(--primary-color);
        padding: 3px 10px;
        border-radius: 6px;
        font-weight: 700;
    }

    .header-actions {
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }

    .btn-back {
        background: var(--gray-100);
        color: var(--gray-700);
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.375rem;
        text-decoration: none;
        transition: background 0.15s;
    }

    .btn-back:hover {
        background: var(--gray-200);
        color: var(--gray-800);
    }

    .btn-edit-page {
        background: rgba(217, 119, 6, 0.1);
        color: #d97706;
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.375rem;
        transition: all 0.15s;
        text-decoration: none;
    }

    .btn-edit-page:hover {
        background: rgba(217, 119, 6, 0.2);
        color: #d97706;
    }

    .btn-delete-page {
        background: rgba(220, 38, 38, 0.1);
        color: #dc2626;
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.375rem;
        transition: all 0.15s;
        text-decoration: none;
    }

    .btn-delete-page:hover {
        background: rgba(220, 38, 38, 0.2);
        color: #dc2626;
    }

    .detail-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
    }

    .detail-full {
        grid-column: 1 / -1;
    }

    .info-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 1px 8px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .info-card-header {
        padding: 0.875rem 1.25rem;
        border-bottom: 1px solid var(--gray-100);
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--gray-600);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        background: var(--gray-50);
    }

    .info-card-header-left {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .info-card-body {
        padding: 1.25rem;
    }

    .truck-image-wrap {
        aspect-ratio: 16/9;
        border-radius: 10px;
        overflow: hidden;
        background: var(--gray-100);
    }

    .truck-image-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .no-image-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--gray-200);
        gap: 0.5rem;
        min-height: 200px;
    }

    .no-image-placeholder i { font-size: 3rem; }
    .no-image-placeholder span { font-size: 0.85rem; color: var(--gray-600); }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.625rem 0;
        border-bottom: 1px solid var(--gray-100);
        font-size: 0.875rem;
        gap: 1rem;
    }

    .info-row:last-child { border-bottom: none; }

    .info-row .label {
        color: var(--gray-600);
        flex-shrink: 0;
    }

    .info-row .value {
        font-weight: 500;
        color: var(--gray-800);
        text-align: right;
    }

    .value-green { color: #059669 !important; }
    .value-red   { color: #dc2626 !important; }
    .value-blue  { color: #2563eb !important; }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .stat-box {
        background: white;
        border-radius: 12px;
        padding: 1.25rem;
        text-align: center;
        border: 1px solid var(--gray-200);
        box-shadow: 0 1px 8px rgba(0,0,0,0.04);
    }

    .stat-value {
        font-size: 1.375rem;
        font-weight: 700;
        color: var(--gray-800);
        display: block;
    }

    .stat-label {
        font-size: 0.72rem;
        color: var(--gray-600);
        margin-top: 0.25rem;
        display: block;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .expense-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }

    .expense-table th {
        padding: 0.625rem 0.875rem;
        text-align: left;
        background: var(--gray-50);
        color: var(--gray-600);
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-bottom: 2px solid var(--gray-200);
    }

    .expense-table td {
        padding: 0.625rem 0.875rem;
        border-bottom: 1px solid var(--gray-100);
        color: var(--gray-700);
    }

    .expense-table tr:last-child td { border-bottom: none; }

    .expense-total-row td {
        font-weight: 700;
        color: var(--gray-800);
        border-top: 2px solid var(--gray-200) !important;
        background: var(--gray-50);
    }

    .doc-list-page {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .doc-item-page {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.625rem 0.875rem;
        background: var(--gray-50);
        border-radius: 8px;
        border: 1px solid var(--gray-200);
        gap: 0.5rem;
        transition: border-color 0.15s;
    }

    .doc-item-page:hover { border-color: var(--primary-color); }

    .doc-item-page a {
        color: var(--primary-color);
        text-decoration: none;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 0.375rem;
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .doc-item-page a:hover { text-decoration: underline; }

    .doc-delete-btn {
        background: rgba(220,38,38,0.1);
        color: #dc2626;
        border: none;
        border-radius: 6px;
        padding: 0.25rem 0.5rem;
        cursor: pointer;
        font-size: 0.8rem;
        transition: background 0.15s;
        flex-shrink: 0;
    }

    .doc-delete-btn:hover { background: rgba(220,38,38,0.2); }

    .btn-upload-doc {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        background: rgba(37,99,235,0.1);
        color: var(--primary-color);
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        margin-top: 0.875rem;
        transition: background 0.15s;
    }

    .btn-upload-doc:hover { background: rgba(37,99,235,0.2); }

    @media (max-width: 768px) {
        .detail-layout  { grid-template-columns: 1fr; }
        .stats-grid     { grid-template-columns: 1fr 1fr; }
        .detail-page-header { flex-direction: column; }
        .header-actions { width: 100%; flex-wrap: wrap; }
    }

    @media (max-width: 480px) {
        .stats-grid { grid-template-columns: 1fr; }
    }
</style>
{% endblock %}

{% block content %}

<!-- Header -->
<div class="detail-page-header">
    <div class="detail-page-title">
        <i class="bi bi-truck"></i>
        {{ truck.make }} {{ truck.model }}
        <span class="po-tag">{{ truck.po_id }}</span>
    </div>
    <div class="header-actions">
        <a href="{% url 'trucks_list' %}" class="btn-back">
            <i class="bi bi-arrow-left"></i> Back
        </a>
        <a href="{% url 'edit_truck' truck.id %}" class="btn-edit-page">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a href="{% url 'delete_truck' truck.id %}"
           class="btn-delete-page"
           onclick="return confirm('Are you sure you want to delete {{ truck.po_id }}: {{ truck.make|escapejs }} {{ truck.model|escapejs }}?\nThis action cannot be undone.')">
            <i class="bi bi-trash"></i> Delete
        </a>
    </div>
</div>

<!-- Stats -->
<div class="stats-grid">
    <div class="stat-box">
        <span class="stat-value" style="color:#059669;">${{ truck.price|floatformat:"0" }}</span>
        <span class="stat-label">Purchase Price</span>
    </div>
    <div class="stat-box">
        <span class="stat-value" style="color:#dc2626;">${{ xarajat_sum|floatformat:"0" }}</span>
        <span class="stat-label">Total Expenses</span>
    </div>
    <div class="stat-box">
        <span class="stat-value">${{ umumiy_narx|floatformat:"0" }}</span>
        <span class="stat-label">Total Cost</span>
    </div>
</div>

<!-- Main Layout -->
<div class="detail-layout">

    <!-- Photo -->
    <div class="info-card">
        <div class="info-card-header">
            <div class="info-card-header-left"><i class="bi bi-image"></i> Photo</div>
        </div>
        <div class="info-card-body">
            <div class="truck-image-wrap">
                {% if truck.image %}
                    <img src="{{ truck.image.url }}" alt="{{ truck.make }} {{ truck.model }}">
                {% else %}
                    <div class="no-image-placeholder">
                        <i class="bi bi-image"></i>
                        <span>No image available</span>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Truck Details -->
    <div class="info-card">
        <div class="info-card-header">
            <div class="info-card-header-left"><i class="bi bi-info-circle"></i> Truck Details</div>
        </div>
        <div class="info-card-body">
            <div class="info-row">
                <span class="label">PO ID</span>
                <span class="value value-blue">{{ truck.po_id }}</span>
            </div>
            <div class="info-row">
                <span class="label">Make</span>
                <span class="value">{{ truck.make }}</span>
            </div>
            <div class="info-row">
                <span class="label">Model</span>
                <span class="value">{{ truck.model }}</span>
            </div>
            <div class="info-row">
                <span class="label">Year</span>
                <span class="value">{{ truck.year }}</span>
            </div>
            <div class="info-row">
                <span class="label">Horsepower</span>
                <span class="value">{{ truck.horsepower|default:"—" }} HP</span>
            </div>
            <div class="info-row">
                <span class="label">Serial Number</span>
                <span class="value">{{ truck.seriya|default:"—" }}</span>
            </div>
            <div class="info-row">
                <span class="label">Location</span>
                <span class="value">{{ truck.location|default:"—" }}</span>
            </div>
            <div class="info-row">
                <span class="label">Company</span>
                <span class="value">{{ truck.company|default:"—" }}</span>
            </div>
            <div class="info-row">
                <span class="label">Price</span>
                <span class="value value-green">${{ truck.price|floatformat:"0" }}</span>
            </div>
            {% if request.user.is_superuser %}
            <div class="info-row">
                <span class="label">Owner</span>
                <span class="value">{{ truck.user.username }}</span>
            </div>
            {% endif %}
        </div>
    </div>

    <!-- Description -->
    {% if truck.description %}
    <div class="info-card detail-full">
        <div class="info-card-header">
            <div class="info-card-header-left"><i class="bi bi-card-text"></i> Description</div>
        </div>
        <div class="info-card-body">
            <p style="color:var(--gray-700); line-height:1.7; margin:0; font-size:0.9rem;">{{ truck.description }}</p>
        </div>
    </div>
    {% endif %}

    <!-- Expenses -->
    <div class="info-card {% if not truck.description %}detail-full{% endif %}">
        <div class="info-card-header">
            <div class="info-card-header-left"><i class="bi bi-receipt"></i> Expenses</div>
        </div>
        <div class="info-card-body" style="padding:0;">
            {% if xarajatlar %}
            <table class="expense-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Type</th>
                        <th style="text-align:right;">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    {% for x in xarajatlar %}
                    <tr>
                        <td>{{ x.nomi|default:"—" }}</td>
                        <td>{{ x.turi|default:"—" }}</td>
                        <td style="text-align:right; color:#dc2626; font-weight:600;">${{ x.amount|floatformat:"0" }}</td>
                    </tr>
                    {% endfor %}
                    <tr class="expense-total-row">
                        <td colspan="2">Total Expenses</td>
                        <td style="text-align:right; color:#dc2626;">${{ xarajat_sum|floatformat:"0" }}</td>
                    </tr>
                </tbody>
            </table>
            {% else %}
            <div style="padding:1.5rem; text-align:center; color:var(--gray-600); font-size:0.875rem;">
                <i class="bi bi-receipt" style="font-size:1.75rem; display:block; margin-bottom:0.5rem; color:var(--gray-200);"></i>
                No expenses recorded
            </div>
            {% endif %}
        </div>
    </div>

    <!-- Documents -->
    <div class="info-card {% if truck.description %}detail-full{% endif %}">
        <div class="info-card-header">
            <div class="info-card-header-left">
                <i class="bi bi-file-earmark-text"></i> Documents
                <span style="background:var(--gray-200); color:var(--gray-700); border-radius:20px; padding:1px 8px; font-size:0.72rem; font-weight:700; margin-left:2px;">
                    {{ hujjatlar|length }}
                </span>
            </div>
        </div>
        <div class="info-card-body">
            {% if hujjatlar %}
            <div class="doc-list-page" id="docListPage">
                {% for h in hujjatlar %}
                <div class="doc-item-page" id="docPage_{{ h.id }}">
                    <a href="{{ h.hujjat_url }}" target="_blank">
                        <i class="bi bi-file-earmark-arrow-down"></i>
                        {{ h.original_file_name }}
                    </a>
                    <button class="doc-delete-btn" onclick="deleteDocPage({{ h.id }})" title="Delete">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <div style="text-align:center; color:var(--gray-600); font-size:0.875rem; padding:0.25rem 0 0.75rem;">
                <i class="bi bi-file-earmark" style="font-size:1.75rem; display:block; color:var(--gray-200); margin-bottom:0.5rem;"></i>
                No documents uploaded
            </div>
            {% endif %}

            <button class="btn-upload-doc"
                onclick="openFormSidebar('{% url 'upload_hujjat' %}?truck_id={{ truck.id }}', 'Upload Document')">
                <i class="bi bi-upload"></i> Upload Document
            </button>
        </div>
    </div>

</div>
{% endblock %}

{% block extra_js %}
<script>
    async function deleteDocPage(docId) {
        if (!confirm('Are you sure you want to delete this document?')) return;
        try {
            const url = "{% url 'delete_hujjat' 0 %}".replace('/0/', '/' + docId + '/');
            const resp = await fetch(url, {
                method: 'DELETE',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'X-CSRFToken': getCookie('csrftoken')
                }
            });
            const data = await resp.json();
            if (data.success) {
                const el = document.getElementById('docPage_' + docId);
                if (el) el.remove();
                window.showAlert('success', 'Document deleted successfully');
            } else {
                window.showAlert('danger', data.message || 'Failed to delete document');
            }
        } catch (e) {
            window.showAlert('danger', 'An error occurred');
        }
    }
</script>
{% endblock %}
{% extends 'base.html' %}
{% block title %}Expenses List - Truck Trade{% endblock %}

{% block extra_css %}
<style>
    :root {
        --primary: #4361ee;
        --secondary: #3f37c9;
        --danger: #f72585;
        --success-color: #10b981;
        --warning: #f8961e;
        --gray-50:  #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-400: #9ca3af;
        --gray-600: #6b7280;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --shadow-sm: 0 1px 4px rgba(0,0,0,0.07);
        --shadow-md: 0 4px 14px rgba(0,0,0,0.1);
        --radius-sm: 0.375rem;
        --radius-md: 0.625rem;
        --transition: all 0.2s ease;
    }

    .page-wrapper { max-width: 1400px; margin: 0 auto; padding: 2rem 1.25rem; }

    .page-header {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;
    }
    .page-title { font-size: 1.5rem; font-weight: 700; color: var(--gray-800); margin: 0; display: flex; align-items: center; gap: 0.5rem; }

    .btn-primary-add {
        background: var(--primary); color: white; border: none;
        padding: 0.6rem 1.25rem; border-radius: var(--radius-sm);
        font-weight: 600; font-size: 0.875rem; cursor: pointer;
        display: inline-flex; align-items: center; gap: 0.4rem;
        text-decoration: none; transition: var(--transition);
    }
    .btn-primary-add:hover { background: var(--secondary); transform: translateY(-1px); box-shadow: var(--shadow-md); color: white; }

    /* Stats */
    .stats-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 1rem; margin-bottom: 1.5rem; }
    .stat-card { background: white; border-radius: var(--radius-md); padding: 1.125rem 1.25rem; box-shadow: var(--shadow-sm); border-left: 4px solid var(--gray-200); }
    .stat-card.s-blue   { border-color: var(--primary); }
    .stat-card.s-red    { border-color: var(--danger); }
    .stat-card.s-green  { border-color: var(--success-color); }
    .stat-card.s-orange { border-color: var(--warning); }
    .stat-val { font-size: 1.5rem; font-weight: 700; color: var(--gray-800); }
    .stat-val.c-blue   { color: var(--primary); }
    .stat-val.c-red    { color: var(--danger); }
    .stat-val.c-green  { color: var(--success-color); }
    .stat-val.c-orange { color: var(--warning); }
    .stat-lbl { font-size: 0.7rem; color: var(--gray-600); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.2rem; }

    /* Filter */
    .filter-card {
        background: white; border-radius: var(--radius-md); box-shadow: var(--shadow-sm);
        padding: 1rem 1.25rem; margin-bottom: 1.25rem;
        display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: flex-end;
    }
    .fld { display: flex; flex-direction: column; gap: 0.25rem; flex: 1; min-width: 140px; }
    .fld label { font-size: 0.7rem; font-weight: 700; color: var(--gray-600); text-transform: uppercase; letter-spacing: 0.04em; }
    .fld input, .fld select {
        border: 1px solid var(--gray-200); border-radius: var(--radius-sm);
        padding: 0.45rem 0.75rem; font-size: 0.875rem; color: var(--gray-800);
        background: var(--gray-50); height: 38px; transition: border-color 0.15s;
    }
    .fld input:focus, .fld select:focus { outline: none; border-color: var(--primary); background: white; }
    .btn-reset {
        background: var(--gray-100); color: var(--gray-600); border: 1px solid var(--gray-200);
        border-radius: var(--radius-sm); padding: 0 1rem; height: 38px;
        font-size: 0.8rem; cursor: pointer; white-space: nowrap; transition: var(--transition); align-self: flex-end;
    }
    .btn-reset:hover { background: var(--gray-200); color: var(--gray-800); }

    /* Table */
    .table-card { background: white; border-radius: var(--radius-md); box-shadow: var(--shadow-sm); overflow: hidden; }
    .data-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .data-table th {
        padding: 0.75rem 1rem; text-align: left; background: var(--gray-100);
        color: var(--gray-600); font-size: 0.7rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.05em;
        border-bottom: 2px solid var(--gray-200); white-space: nowrap;
    }
    .data-table td { padding: 0.875rem 1rem; border-bottom: 1px solid var(--gray-200); color: var(--gray-700); vertical-align: middle; }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tbody tr:hover { background: var(--gray-50); }

    .po-badge { background: rgba(67,97,238,0.1); color: var(--primary); padding: 2px 9px; border-radius: 5px; font-weight: 700; font-size: 0.78rem; }
    .truck-name { font-weight: 600; color: var(--gray-800); }
    .truck-sub  { font-size: 0.75rem; color: var(--gray-400); margin-top: 2px; }
    .amount-green { color: #059669; font-weight: 600; }
    .amount-red   { color: #dc2626; font-weight: 600; }

    .pay-badge { display: inline-flex; align-items: center; gap: 0.25rem; padding: 3px 9px; border-radius: 20px; font-size: 0.73rem; font-weight: 600; white-space: nowrap; }
    .pay-overdue { background: rgba(247,37,133,0.1); color: #f72585; }
    .pay-warning { background: rgba(248,150,30,0.12); color: #d97706; }
    .pay-ok      { background: rgba(16,185,129,0.1);  color: #059669; }
    .pay-done    { background: rgba(107,114,128,0.1); color: #6b7280; }

    .overdue-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 3px; }
    .overdue-item { background: rgba(247,37,133,0.07); border: 1px solid rgba(247,37,133,0.18); border-radius: 5px; padding: 3px 8px; font-size: 0.72rem; color: #c4185a; }

    .action-buttons { display: flex; gap: 0.375rem; flex-wrap: wrap; }
    .btn-act { border: none; padding: 0.32rem 0.65rem; border-radius: var(--radius-sm); font-size: 0.78rem; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; gap: 0.25rem; transition: var(--transition); text-decoration: none; }
    .btn-edit    { background: rgba(67,97,238,0.1);  color: var(--primary); }
    .btn-edit:hover    { background: rgba(67,97,238,0.2); color: var(--primary); }
    .btn-delete  { background: rgba(247,37,133,0.1); color: var(--danger); }
    .btn-delete:hover  { background: rgba(247,37,133,0.2); color: var(--danger); }
    .btn-payment { background: rgba(16,185,129,0.1); color: #059669; }
    .btn-payment:hover { background: rgba(16,185,129,0.2); color: #059669; }
    .btn-detail  { background: rgba(107,114,128,0.1); color: #374151; }
    .btn-detail:hover  { background: rgba(107,114,128,0.2); color: #111827; }

    .empty-state { padding: 3rem; text-align: center; color: var(--gray-600); }
    .empty-state i { font-size: 2.5rem; color: var(--gray-200); display: block; margin-bottom: 0.75rem; }

    /* Pagination */
    .pagination-wrap { display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.25rem; border-top: 1px solid var(--gray-200); flex-wrap: wrap; gap: 0.75rem; }
    .page-info { font-size: 0.8rem; color: var(--gray-600); }
    .pagination { display: flex; gap: 0.25rem; list-style: none; padding: 0; margin: 0; }
    .pagination .page-link { display: inline-flex; align-items: center; justify-content: center; min-width: 34px; height: 34px; padding: 0 0.5rem; border-radius: var(--radius-sm); border: 1px solid var(--gray-200); font-size: 0.82rem; color: var(--gray-700); text-decoration: none; transition: var(--transition); background: white; }
    .pagination .page-link:hover { background: var(--gray-100); }
    .pagination .active .page-link { background: var(--primary); color: white; border-color: var(--primary); }
    .pagination .disabled .page-link { color: var(--gray-200); pointer-events: none; }

    /* Delete Modal */
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 9999; align-items: center; justify-content: center; }
    .modal-overlay.show { display: flex; }
    .modal-box { background: white; border-radius: 12px; padding: 2rem; max-width: 420px; width: 90%; box-shadow: 0 20px 60px rgba(0,0,0,0.2); }
    .modal-icon { width: 56px; height: 56px; background: rgba(247,37,133,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; }
    .modal-actions { display: flex; gap: 0.75rem; justify-content: center; margin-top: 1.25rem; }
    .btn-modal-cancel { background: var(--gray-100); border: 1px solid var(--gray-200); border-radius: 6px; padding: 0.6rem 1.5rem; font-weight: 600; cursor: pointer; font-size: 0.875rem; color: var(--gray-700); }
    .btn-modal-delete { background: var(--danger); color: white; border: none; border-radius: 6px; padding: 0.6rem 1.5rem; font-weight: 600; cursor: pointer; font-size: 0.875rem; display: inline-flex; align-items: center; gap: 0.375rem; }
    .btn-modal-delete:disabled { opacity: 0.65; }

    @keyframes spin-modal { to { transform: rotate(360deg); } }
    .spin-icon { display: inline-block; width: 13px; height: 13px; border: 2px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%; animation: spin-modal .7s linear infinite; }

    @media (max-width: 992px) { .stats-row { grid-template-columns: repeat(2,1fr); } }
    @media (max-width: 768px) {
        .stats-row { grid-template-columns: 1fr 1fr; }
        .data-table-wrap { overflow-x: auto; }
        .data-table { min-width: 900px; }
    }
    @media (max-width: 480px) {
        .stats-row { grid-template-columns: 1fr; }
        .filter-card { flex-direction: column; }
        .fld { min-width: 100%; }
        .page-wrapper { padding: 1rem 0.75rem; }
    }
</style>
{% endblock %}

{% block content %}
<div class="page-wrapper">

    <div class="page-header">
        <h1 class="page-title"><i class="bi bi-cash-stack"></i> Expenses List</h1>
        <a href="{% url 'chiqim_add' %}" class="btn-primary-add">
            <i class="bi bi-plus-circle"></i> Add New Expense
        </a>
    </div>

    <!-- Stats -->
    <div class="stats-row">
        <div class="stat-card s-blue">
            <div class="stat-val c-blue">{{ page_obj.paginator.count }}</div>
            <div class="stat-lbl">Total Records</div>
        </div>
        <div class="stat-card s-red">
            <div class="stat-val c-red">{{ overdue_count }}</div>
            <div class="stat-lbl">Overdue Payments</div>
        </div>
        <div class="stat-card s-green">
            <div class="stat-val c-green">{{ chiqimlar|length }}</div>
            <div class="stat-lbl">This Page</div>
        </div>
        <div class="stat-card s-orange">
            <div class="stat-val c-orange">{{ page_obj.paginator.num_pages }}</div>
            <div class="stat-lbl">Total Pages</div>
        </div>
    </div>

    <!-- Filters -->
    <div class="filter-card">
        <div class="fld" style="flex:2; min-width:180px;">
            <label><i class="bi bi-search"></i> Search</label>
            <input type="text" id="filterSearch" placeholder="PO-ID, truck, buyer...">
        </div>
        <div class="fld">
            <label>Payment Status</label>
            <select id="filterStatus">
                <option value="">All</option>
                <option value="overdue">Overdue</option>
                <option value="upcoming">Upcoming (≤7 days)</option>
                <option value="ok">On Track</option>
                <option value="completed">Completed</option>
            </select>
        </div>
        <div class="fld">
            <label>Sort By</label>
            <select id="filterSort">
                <option value="">Default</option>
                <option value="days_asc">Days Left ↑</option>
                <option value="days_desc">Days Left ↓</option>
                <option value="price_asc">Price ↑</option>
                <option value="price_desc">Price ↓</option>
            </select>
        </div>
        <button class="btn-reset" onclick="resetFilters()">
            <i class="bi bi-x-circle"></i> Reset
        </button>
    </div>

    <!-- Table -->
    <div class="table-card">
        {% if chiqimlar %}
        <div class="data-table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>PO-ID</th>
                        <th>Vehicle</th>
                        <th>Buyer</th>
                        <th>Price</th>
                        <th>Paid</th>
                        <th>Balance</th>
                        <th>Next Payment</th>
                        <th>Overdue</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    {% for chiqim in chiqimlar %}
                    <tr
                        data-search="{{ chiqim.truck.po_id|lower }} {{ chiqim.truck.make|lower }} {{ chiqim.truck.model|lower }} {{ chiqim.xaridor.ism_familiya|lower }}"
                        data-days="{{ chiqim.days_until_payment|default:'99999' }}"
                        data-price="{{ chiqim.narx }}"
                        data-pay-status="{% if chiqim.days_until_payment is None %}completed{% elif chiqim.days_until_payment < 0 %}overdue{% elif chiqim.days_until_payment <= 7 %}upcoming{% else %}ok{% endif %}"
                    >
                        <td style="color:var(--gray-400); font-size:0.8rem;">
                            {{ page_obj.start_index|add:forloop.counter0 }}
                        </td>
                        <td><span class="po-badge">{{ chiqim.truck.po_id }}</span></td>
                        <td>
                            <div class="truck-name">{{ chiqim.truck.make }} {{ chiqim.truck.model|default:"" }}</div>
                            {% if chiqim.truck.seriya %}
                            <div class="truck-sub">SN: {{ chiqim.truck.seriya }}</div>
                            {% endif %}
                        </td>
                        <td>
                            <div class="truck-name">{{ chiqim.xaridor.ism_familiya|default:"—" }}</div>
                            {% if chiqim.xaridor.telefon_raqam %}
                            <div class="truck-sub"><i class="bi bi-telephone" style="font-size:0.65rem;"></i> {{ chiqim.xaridor.telefon_raqam }}</div>
                            {% endif %}
                        </td>
                        <td class="amount-green">${{ chiqim.narx|floatformat:2 }}</td>
                        <td>${{ chiqim.tolangan_summa|floatformat:2 }}</td>
                        <td class="amount-red">${{ chiqim.qoldiq_summa|floatformat:2 }}</td>
                        <td>
                            {% if chiqim.next_payment_date %}
                                <div style="font-size:0.82rem; font-weight:600; margin-bottom:3px;">
                                    {{ chiqim.next_payment_date|date:"M d, Y" }}
                                </div>
                                {% if chiqim.days_until_payment < 0 %}
                                    <span class="pay-badge pay-overdue">
                                        <i class="bi bi-exclamation-circle-fill"></i>
                                        {{ chiqim.days_until_payment|cut:"-" }}d overdue
                                    </span>
                                {% elif chiqim.days_until_payment <= 7 %}
                                    <span class="pay-badge pay-warning">
                                        <i class="bi bi-clock-fill"></i>
                                        {{ chiqim.days_until_payment }}d left
                                    </span>
                                {% else %}
                                    <span class="pay-badge pay-ok">
                                        <i class="bi bi-check-circle"></i>
                                        {{ chiqim.days_until_payment }}d left
                                    </span>
                                {% endif %}
                            {% else %}
                                <span class="pay-badge pay-done">
                                    <i class="bi bi-check2-all"></i> Completed
                                </span>
                            {% endif %}
                        </td>
                        <td>
                            {% if chiqim.overdue_notifications %}
                            <ul class="overdue-list">
                                {% for notif in chiqim.overdue_notifications %}
                                <li class="overdue-item">
                                    <i class="bi bi-calendar-x"></i>
                                    {{ notif.tolov_sana|date:"M d" }} — <strong>{{ notif.days_overdue }}d</strong>
                                </li>
                                {% endfor %}
                            </ul>
                            {% else %}
                            <span style="color:var(--gray-400); font-size:0.8rem;">—</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-act btn-edit" onclick="openEditForm({{ chiqim.id }})">
                                    <i class="bi bi-pencil"></i> Edit
                                </button>
                                <button class="btn-act btn-delete" onclick="showDeleteModal({{ chiqim.id }}, '{{ chiqim.truck.po_id }}')">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                                <button class="btn-act btn-payment" onclick="openPaymentForm({{ chiqim.id }})">
                                    <i class="bi bi-cash-coin"></i> Payment
                                </button>
                                <a href="{% url 'chiqim_detail' chiqim.id %}" class="btn-act btn-detail">
                                    <i class="bi bi-eye"></i> Details
                                </a>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                    <tr id="noResultsRow" style="display:none;">
                        <td colspan="10" style="text-align:center; color:var(--gray-400); padding:2.5rem; font-size:0.875rem;">
                            <i class="bi bi-search" style="font-size:1.75rem; display:block; margin-bottom:0.5rem;"></i>
                            No records match your filter.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        {% if is_paginated %}
        <div class="pagination-wrap">
            <span class="page-info">
                Page <strong>{{ page_obj.number }}</strong> of <strong>{{ page_obj.paginator.num_pages }}</strong>
                &nbsp;·&nbsp; {{ page_obj.paginator.count }} total records
            </span>
            <ul class="pagination">
                {% if page_obj.has_previous %}
                    <li><a class="page-link" href="?page=1"><i class="bi bi-chevron-double-left"></i></a></li>
                    <li><a class="page-link" href="?page={{ page_obj.previous_page_number }}"><i class="bi bi-chevron-left"></i></a></li>
                {% else %}
                    <li class="disabled"><span class="page-link"><i class="bi bi-chevron-double-left"></i></span></li>
                    <li class="disabled"><span class="page-link"><i class="bi bi-chevron-left"></i></span></li>
                {% endif %}

                {% for num in page_obj.paginator.page_range %}
                    {% if page_obj.number == num %}
                        <li class="active"><span class="page-link">{{ num }}</span></li>
                    {% elif num > page_obj.number|add:"-3" and num < page_obj.number|add:"3" %}
                        <li><a class="page-link" href="?page={{ num }}">{{ num }}</a></li>
                    {% endif %}
                {% endfor %}

                {% if page_obj.has_next %}
                    <li><a class="page-link" href="?page={{ page_obj.next_page_number }}"><i class="bi bi-chevron-right"></i></a></li>
                    <li><a class="page-link" href="?page={{ page_obj.paginator.num_pages }}"><i class="bi bi-chevron-double-right"></i></a></li>
                {% else %}
                    <li class="disabled"><span class="page-link"><i class="bi bi-chevron-right"></i></span></li>
                    <li class="disabled"><span class="page-link"><i class="bi bi-chevron-double-right"></i></span></li>
                {% endif %}
            </ul>
        </div>
        {% endif %}

        {% else %}
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <p>No expenses found</p>
            <p style="font-size:0.82rem; color:var(--gray-400); margin-top:0.5rem;">
                <a href="{% url 'chiqim_add' %}" style="color:var(--primary);">Add your first expense</a>
            </p>
        </div>
        {% endif %}
    </div>

    <!-- Delete Modal -->
    <div class="modal-overlay" id="deleteModal">
        <div class="modal-box">
            <div style="text-align:center;">
                <div class="modal-icon">
                    <i class="bi bi-trash" style="font-size:1.5rem; color:var(--danger);"></i>
                </div>
                <h3 style="margin:0 0 0.5rem; font-size:1.1rem; font-weight:700; color:var(--gray-800);">Delete Expense?</h3>
                <p style="margin:0; color:var(--gray-600); font-size:0.875rem;" id="deleteModalText">This action cannot be undone.</p>
            </div>
            <div class="modal-actions">
                <button class="btn-modal-cancel" onclick="closeDeleteModal()">Cancel</button>
                <button class="btn-modal-delete" id="confirmDeleteBtn">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>

</div>
{% endblock %}

{% block extra_js %}
<script>
/* ── Filter & Sort ── */
const filterSearch = document.getElementById('filterSearch');
const filterStatus = document.getElementById('filterStatus');
const filterSort   = document.getElementById('filterSort');
const tableBody    = document.getElementById('tableBody');
const noResultsRow = document.getElementById('noResultsRow');

function applyFilters() {
    if (!tableBody) return;
    const term   = (filterSearch?.value || '').toLowerCase().trim();
    const status = filterStatus?.value || '';
    const sort   = filterSort?.value || '';

    let rows = Array.from(tableBody.querySelectorAll('tr:not(#noResultsRow)'));

    rows.forEach(row => {
        const matchSearch = !term   || (row.dataset.search || '').toLowerCase().includes(term);
        const matchStatus = !status || (row.dataset.payStatus || '') === status;
        row.style.display = matchSearch && matchStatus ? '' : 'none';
    });

    const visible = rows.filter(r => r.style.display !== 'none');

    if (sort) {
        visible.sort((a, b) => {
            if (sort === 'days_asc')   return parseFloat(a.dataset.days)  - parseFloat(b.dataset.days);
            if (sort === 'days_desc')  return parseFloat(b.dataset.days)  - parseFloat(a.dataset.days);
            if (sort === 'price_asc')  return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
            if (sort === 'price_desc') return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
            return 0;
        });
        visible.forEach(r => tableBody.insertBefore(r, noResultsRow));
    }

    if (noResultsRow) noResultsRow.style.display = visible.length === 0 ? '' : 'none';
}

function resetFilters() {
    if (filterSearch) filterSearch.value = '';
    if (filterStatus) filterStatus.value = '';
    if (filterSort)   filterSort.value   = '';
    applyFilters();
}

filterSearch?.addEventListener('input', applyFilters);
filterStatus?.addEventListener('change', applyFilters);
filterSort?.addEventListener('change', applyFilters);

/* ── Delete Modal ── */
let pendingDeleteId = null;
const deleteModal = document.getElementById('deleteModal');

function showDeleteModal(id, poId) {
    pendingDeleteId = id;
    document.getElementById('deleteModalText').textContent =
        `Delete expense for "${poId}"? This action cannot be undone.`;
    deleteModal.classList.add('show');
}

function closeDeleteModal() {
    deleteModal.classList.remove('show');
    pendingDeleteId = null;
}

deleteModal?.addEventListener('click', e => { if (e.target === deleteModal) closeDeleteModal(); });

document.getElementById('confirmDeleteBtn')?.addEventListener('click', async () => {
    if (!pendingDeleteId) return;
    const btn = document.getElementById('confirmDeleteBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spin-icon"></span> Deleting...';
    try {
        const resp = await fetch(`/chiqim/delete/${pendingDeleteId}/`, {
            method: 'POST',
            headers: { 'X-CSRFToken': getCookie('csrftoken'), 'X-Requested-With': 'XMLHttpRequest' },
            credentials: 'same-origin'
        });
        const data = await resp.json();
        closeDeleteModal();
        if (data.success) {
            window.showAlert?.('success', 'Expense deleted successfully!');
            setTimeout(() => location.reload(), 1000);
        } else {
            window.showAlert?.('danger', data.error || 'Delete failed');
        }
    } catch {
        closeDeleteModal();
        window.showAlert?.('danger', 'Server connection error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-trash"></i> Delete';
    }
});

/* ── Sidebar forms ── */
function bindSidebarForm(formId, url, msg) {
    setTimeout(() => {
        const form = document.getElementById(formId);
        if (!form || form.dataset.bound) return;
        form.dataset.bound = '1';
        form.addEventListener('submit', async e => {
            e.preventDefault();
            const btn  = form.querySelector('button[type="submit"]');
            const orig = btn?.innerHTML;
            if (btn) { btn.disabled = true; btn.innerHTML = 'Saving...'; }
            try {
                const resp = await fetch(url, {
                    method: 'POST',
                    body: new FormData(form),
                    headers: { 'X-CSRFToken': getCookie('csrftoken'), 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin'
                });
                const data = await resp.json();
                if (data.success) {
                    window.showAlert?.('success', msg || 'Saved!');
                    window.closeFormSidebar?.();
                    setTimeout(() => location.reload(), 1200);
                } else {
                    if (data.errors) {
                        Object.entries(data.errors).forEach(([field, msgs]) => {
                            const input = form.querySelector(`#id_${field}`);
                            if (input) input.style.outline = '2px solid #f72585';
                        });
                    }
                    window.showAlert?.('danger', data.error || 'Error occurred');
                }
            } catch { window.showAlert?.('danger', 'Connection error'); }
            finally { if (btn) { btn.disabled = false; btn.innerHTML = orig; } }
        });
    }, 500);
}

window.openEditForm = id => {
    window.openFormSidebar?.(`/chiqim/edit/${id}/`, 'Edit Expense');
    bindSidebarForm('chiqimForm', `/chiqim/edit/${id}/`, 'Expense updated!');
};
window.openPaymentForm = id => {
    window.openFormSidebar?.(`/chiqim/payment/add/${id}/`, 'Add Payment');
    bindSidebarForm('tolovForm', `/chiqim/payment/add/${id}/`, 'Payment added!');
};
</script>
